{
  "version": "1.0",
  "description": "기본 단타 매매 규칙 - 스켈레톤",
  "trading": {
    "stop_loss_pct": 3.0,
    "take_profit_pct": 5.0,
    "trailing_stop_pct": 1.5,
    "max_position_size_pct": 10.0,
    "max_concurrent_positions": 5,
    "min_order_amount_krw": 5000,
    "cooldown_seconds": 60,
    "sell_lock_before_date": "2026-02-27"
  },
  "indicators": {
    "rsi": {
      "enabled": true,
      "period": 14,
      "oversold": 30,
      "overbought": 70
    },
    "macd": {
      "enabled": false,
      "fast_period": 12,
      "slow_period": 26,
      "signal_period": 9
    },
    "volume_spike": {
      "enabled": true,
      "threshold_multiplier": 2.0,
      "lookback_periods": 20
    },
    "bollinger_bands": {
      "enabled": false,
      "period": 20,
      "std_dev": 2.0
    },
    "moving_average": {
      "enabled": false,
      "short_period": 5,
      "long_period": 20,
      "type": "EMA"
    }
  },
  "filters": {
    "min_volume_24h_krw": 1000000000,
    "min_price_krw": 100,
    "blacklist": [],
    "whitelist": []
  },
  "signal_weights": {
    "technical": 0.6,
    "news": 0.3,
    "twitter": 0.1
  },
  "interrupt": {
    "enabled": true,
    "news_confidence_threshold": 0.8,
    "twitter_confidence_threshold": 0.9,
    "max_interrupt_position_pct": 5.0
  }
}
